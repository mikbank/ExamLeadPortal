@model ExamLeadPortal.ViewModels.LeadCorrectionEditViewModel

@{
    ViewData["Title"] = "Edit Lead";
}

<h1 class="mb-4">Edit Lead</h1>

<form asp-controller="Lead" asp-action="SaveEdits" method="post">
    <input type="hidden" asp-for="RawLeadId" />

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Core Information</h5>

            <div class="mb-3">
                <label asp-for="LeadTitle" class="form-label">Lead Title</label>
                <input asp-for="LeadTitle" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="LeadSummary" class="form-label">Lead Summary</label>
                <textarea asp-for="LeadSummary" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="LeadValue" class="form-label">Lead Value</label>
                <select asp-for="LeadValue" class="form-select">
                    <option value="">Select value</option>
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                    <option value="Limited">Limited</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="ResourceLink" class="form-label">Resource Link</label>
                <input asp-for="ResourceLink" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Affected BUs</label>

                @foreach (var bu in Model.ValidBUs)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="AffectedBUs"
                               value="@bu"
                               checked="@Model.AffectedBUs.Contains(bu)" />

                        <label class="form-check-label">@bu</label>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Payload Details</h5>

            @if (!Model.PayloadValues.Any())
            {
                <p>No payload fields available.</p>
            }
            else
            {
                @foreach (var item in Model.PayloadValues)
                {
                    <div class="mb-3">
                        <label class="form-label">@item.Key</label>
                        <input type="text"
                               name="PayloadValues[@item.Key]"
                               value="@item.Value"
                               class="form-control" />
                    </div>
                }
            }
        </div>
    </div>

    <button type="submit" class="btn btn-success">Save Edits</button>

    <a asp-controller="Lead"
       asp-action="Details"
       asp-route-id="@Model.RawLeadId"
       class="btn btn-secondary ms-2">
        Cancel
    </a>
</form>