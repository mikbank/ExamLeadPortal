@model ExamLeadPortal.ViewModels.LeadDetailsViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Lead Suggestion Details";
}

@if (Model.Lead == null)
{
    <p>Lead not found.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1>@Model.Lead.LeadTitle</h1>
            <p class="text-muted mb-0">
                Lead ID: @Model.Lead.Id
            </p>
        </div>

        <div>
            @if (Model.IsAlreadyAccepted)
            {
                <button class="btn btn-secondary" disabled>
                    Edit Lead
                </button>

                <span class="text-muted ms-2">
                    Accepted leads cannot be edited.
                </span>
            }
            else
            {
                <a asp-controller="Lead"
                   asp-action="Edit"
                   asp-route-id="@Model.Lead.Id"
                   class="btn btn-primary">
                    Edit Lead
                </a>
            }

            @if (Model.HasCorrections)
            {
                <span class="badge bg-info text-dark ms-2">
                    Contains employee revisions
                </span>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Core Information</h5>
            <p><strong>ID:</strong> @Model.Lead.Id</p>
            <p><strong>Summary:</strong> @Model.Lead.LeadSummary</p>
            <p><strong>Lead Value:</strong> @Model.Lead.LeadValue</p>
            <p><strong>Affected BUs:</strong> @string.Join(", ", Model.Lead.AffectedBUs)</p>
            <p>
                <strong>Resource Link:</strong>
                <a href="@Model.Lead.ResourceLink" target="_blank">@Model.Lead.ResourceLink</a>
            </p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Payload Details</h5>

            @if (Model.Lead.LeadPayload == null || !Model.Lead.LeadPayload.Any())
            {
                <p>No additional payload data available.</p>
            }
            else
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Lead.LeadPayload)
                        {
                            <tr>
                                <td>@item.Key</td>
                                <td>
                                    @{
                                        if (item.Value.ValueKind == JsonValueKind.Array)
                                        {
                                            var values = item.Value.EnumerateArray().Select(x => x.ToString());
                                            @string.Join(", ", values)
                                        }
                                        else
                                        {
                                            @item.Value.ToString()
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Acceptance</h5>

            @if (Model.IsAlreadyAccepted)
            {
                <p class="text-success mb-0">This lead suggestion has already been accepted.</p>
            }
            else
            {
                <form asp-controller="Lead" asp-action="Accept" method="post">
                    <input type="hidden" name="rawLeadId" value="@Model.Lead.Id" />

                    <div class="mb-3">
                        <label class="form-label">Responsible BU</label>
                        <select name="responsibleBU" class="form-select" required>
                            <option value="">Select BU</option>
                            @foreach (var bu in Model.ValidBUs)
                            {
                                <option value="@bu">@bu</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success">Accept Lead</button>
                </form>
            }
        </div>
    </div>

    <a asp-controller="Lead" asp-action="Index" class="btn btn-secondary">Back to Lead Suggestions</a>
}