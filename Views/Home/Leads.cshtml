@model ExamLeadPortal.ViewModels.LeadListViewModel

@{
    ViewData["Title"] = "Leads";
}

<h1 class="mb-4">Leads</h1>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Title</label>
            <input type="text" name="TitleFilter" value="@Model.Filters.TitleFilter" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Lead Value</label>
            <select name="ValueFilter" class="form-select">
                <option value="">All</option>
                <option value="Low" selected="@(Model.Filters.ValueFilter == "Low")">Low</option>
                <option value="Medium" selected="@(Model.Filters.ValueFilter == "Medium")">Medium</option>
                <option value="High" selected="@(Model.Filters.ValueFilter == "High")">High</option>
                <option value="Limited" selected="@(Model.Filters.ValueFilter == "Limited")">Limited</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Affected BU</label>
            <input type="text" name="BuFilter" value="@Model.Filters.BuFilter" class="form-control" />
        </div>

        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

<div style="max-height: 600px; overflow-y: auto; border: 1px solid #ddd; border-radius: 8px; padding: 12px;">
    @if (!Model.Leads.Any())
    {
        <p>No leads found.</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var lead in Model.Leads)
            {
                <a asp-controller="Lead"
                   asp-action="Details"
                   asp-route-id="@lead.Id"
                   class="list-group-item list-group-item-action mb-2 rounded">

                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">@lead.LeadTitle</h5>
                        <small>@lead.LeadValue</small>
                    </div>

                    <p class="mb-1">@lead.LeadSummary</p>
                    <small>
                        <strong>BUs:</strong> @string.Join(", ", lead.AffectedBUs)
                    </small>
                </a>
            }
        </div>
    }
</div>